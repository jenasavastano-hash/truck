# Скопируй в `backend/.env` и заполни секреты.
# API по умолчанию: http://localhost:5000  →  см. README в корне репозитория.

NODE_ENV=development
PORT=5000

# ВАЖНО: в production задайте уникальный секрет (не оставляйте значение по умолчанию из кода).
JWT_SECRET=change-me-in-production

# SQLite создаётся автоматически рядом с приложением (см. database.js).

# Такском API (создание ЭПЛ через API)
TAKSKOM_API_BASE=https://api-epl.taxcom.ru/v1.1/
TAKSKOM_API_KEY=
# Вид коммерческой перевозки для КП (если не задан в данных парка). ПГ — груз по договору; ЛТ — легковое такси (уточните по доке API для вашего договора).
# TAKSKOM_COMMERCIAL_SHIPPING_TYPE=ПГ
# Альтернатива: TAKSKOM_TOKEN=

# URL PDF по mintransId; если не задан — используется путь waybill/{mintransId}/document/pdf
# TAKSKOM_DOCUMENT_PDF_URL=https://api-epl.taxcom.ru/v1.1/waybill/{mintransId}/document/pdf
# DEBUG_TAKSKOM=true

# Публичный URL (QR в PDF, ссылки). На проде — ваш домен с https
# PUBLIC_APP_URL=https://app.example.com

# Дополнительные Origin для CORS (через запятую), если фронт не на localhost
# CORS_ORIGINS=https://app.example.com

# Фронт — редирект после оплаты ЮKassa
FRONTEND_URL=http://localhost:3000

# ЮKassa — пополнение баланса водителя
YOOKASSA_SHOP_ID=
YOOKASSA_API_KEY=

# Telegram (опционально)
# TELEGRAM_BOT_TOKEN=

# Режим создания ЭПЛ: takskom_api | clinic_api (ПК-клиника / signer-client)
# SIGNER_API_KEY=
# CLINIC_API_KEY=
# EPL_SIGN_MODE=mock
# EPL_EXPIRY_JOB_MINUTES=5
# EPL_COMPLETE_DEFAULT_KM=50
