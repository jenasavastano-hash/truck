# Адрес бэкенда
API_URL=http://localhost:5000

# Ключ (тот же, что в backend/.env). Сгенерировать: node backend/generate-signer-key.js
SIGNER_API_KEY=


# Интервал опроса в секундах (заявки на ЭПЛ + титулы на подпись). По умолчанию 20
POLL_SECONDS=20
# Пробег на закрытие ЭПЛ (Т5/Т6): если бэкенд не присылает endOdometer, подставляется начальный пробег + это значение (км). По умолчанию 100.
EPL_ODOMETER_ADD_KM=100

# Путь к .exe подписания КриптоПро. Пусто = подпись только через Playwright (КриптоПро в браузере).
# Контракт: 1-й аргумент — файл с данными, 2-й — роль (dispatcher|medic|mechanic); stdout — base64.
SIGNER_CMD=

# --- Создание и подпись ЭПЛ в ЛК Такском (Playwright) ---
TAKSKOM_URL=https://epl.taxcom.ru
# Диспетчер — создание ЭПЛ и подпись Т1
TAKSKOM_DISPATCHER_PHONE=
TAKSKOM_DISPATCHER_PASSWORD=
# Медик — подпись Т2
TAKSKOM_MEDIC_PHONE=
TAKSKOM_MEDIC_PASSWORD=
# Механик — подпись Т3, Т4
TAKSKOM_MECHANIC_PHONE=
TAKSKOM_MECHANIC_PASSWORD=
# Браузер для Такском (с расширением КриптоПро). Варианты:
# 1) Яндекс.Браузер — поставь USE_YANDEX_BROWSER=1, путь подставится сам (профиль из AppData).
# 2) Любой другой — укажи путь к exe в CHROMIUM_GOST_PATH (ГОСТ, Chrome, Chromium). Профиль: User Data рядом с exe или авто для Chromium/Яндекс.
# Примеры CHROMIUM_GOST_PATH:
#   Яндекс: C:\Users\Имя\AppData\Local\Yandex\YandexBrowser\Application\browser.exe
#   ГОСТ:   D:\Chromium-GOST\chrome.exe
USE_YANDEX_BROWSER=0
CHROMIUM_GOST_PATH=
# Профиль вручную (если авто не подходит): путь к папке "User Data".
TAXCOM_USER_DATA_DIR=
# Отдельные профили для воркеров (диспетчер / медик / механик) — каждый в своём окне. Если не заданы, используется TAXCOM_USER_DATA_DIR или авто.
# DISPATCHER_USER_DATA_DIR=
# MEDIC_USER_DATA_DIR=
# MECHANIC_USER_DATA_DIR=
# Откуда копировать профиль с КриптоПро в profiles/dispatcher, medic, mechanic при первом запуске run-workers.js.
# Если не задано — берётся папка User Data рядом с CHROMIUM_GOST_PATH. Перед первым запуском закрой браузер.
# CRYPTOPRO_SOURCE_PROFILE=C:\path\to\Chromium\User Data
# Exe выбора сертификата в окне КриптоПро. Аргумент: dispatcher|medic|mechanic. См. CLINIC_AUTOMATION_PLAN.md.
# Если не указан, при подписании нужно будет вручную выбирать сертификат в диалоге КриптоПро.
CERT_PICKER_EXE=
# Автоклик «Да» в окне КриптоПро — отключён по умолчанию. Добавь epl.taxcom.ru в доверенные сайты КриптоПро для мгновенной подписи без диалога. 1 = включить (если не в доверенных).
CRYPTOPRO_AUTO_CLICK_ALLOW=1

# Сопоставление сертификатов с ролями (по имени файла .cer или по имени в сертификате)
# Формат: РОЛЬ=ИмяФайла.cer или РОЛЬ=ИмяВСертификате
# Примеры:
# CERT_DISPATCHER=Амиргамзаев.cer
# CERT_MEDIC=Поливода.cer
# CERT_MECHANIC=Иванов.cer
# Если не указано, при подписании нужно будет вручную выбирать сертификат.
CERT_DISPATCHER=
CERT_MEDIC=
CERT_MECHANIC=
# Не закрывать браузер после обработки. 0 = закрывать (рекомендуется для очереди). 1 = отладка — окно остаётся открытым.
TAXCOM_KEEP_BROWSER_OPEN=0
# Ожидание QR в signer: 0 = сразу отпустить браузер, QR заберёт qr-fetcher (~2 мин). 120 = ждать 2 мин (старое).
TAXCOM_QR_WAIT_SECONDS=0
# TAXCOM_HEADLESS=0 — показать браузер при отладке
# Скриншоты при создании ЭПЛ. По умолчанию выключены. Включить: SCREENSHOTS=1 или TAXCOM_SCREENSHOTS=1
# SCREENSHOTS=1
SCREENSHOTS_DIR=screenshots
# Пошаговый режим отладки: после каждого заполненного поля делается скриншот с подсветкой и программа ждёт команды.
# DEBUG_STEP_BY_STEP=1 — включить пошаговую отладку (для проверки каждого поля)
# Команды в режиме отладки:
#   Enter — продолжить дальше
#   s + Enter — пропустить этот шаг
#   b + Enter — вернуться назад (очистить поле и вернуться)
#   Ctrl+C — остановить программу
DEBUG_STEP_BY_STEP=0

# --- Грузовой ЭПЛ (отличие от легкового такси в форме Такском) ---
# Обязательный послесменный/послерейсовый медосмотр: 1 / да (по умолчанию), 0 — выключить (как старый такси-режим)
# TAXCOM_POST_SHIFT_MEDICAL_REQUIRED=1
# Подстроки для выбора option (ЛК может менять тексты — при сбое уточните в HTML селекта)
# TAXCOM_COMMERCIAL_SHIPPING_LABEL=перевозка грузов
# TAXCOM_TRIP_START_LABEL=парковк
# TAXCOM_SHIPPING_KIND_LABEL=коммерческ
# TAXCOM_MESSAGE_KIND_LABEL=городск
# Тип ТС в поле #vehicle_type, если в БД пусто: грузовой | легковой | …
# TAXCOM_DEFAULT_VEHICLE_TYPE=грузовой
# Строгая проверка автозаполнения грузовых адресов. 1 = при незаполненных freight-полях создание ЭПЛ падает с ошибкой (рекомендуется).
TAXCOM_REQUIRE_FREIGHT_AUTOFILL=1
# Чекпоинты между этапами ЭПЛ: после Т1 сохранён, Т1 подписан, Т3 подписан, Т2 подписан программа ждёт Enter в консоли.
# Включи TAXCOM_CHECKPOINTS=1, чтобы проверять каждый этап в Такском и нажимать Enter для продолжения.
TAXCOM_CHECKPOINTS=0

# Лимиты репорта фейлов создания ЭПЛ в /api/worker/epl/:id/create-attempt-failed
WORKER_MAX_CREATE_ATTEMPTS=3
WORKER_MIN_FAIL_REPORT_INTERVAL_SEC=20
# --- QR-fetcher (воркер QR: в отдельном процессе, свой браузер) ---
# Профиль браузера qr-fetcher (отдельно от signer). По умолчанию signer-client/qr-fetcher-profile.
# QR_FETCH_USER_DATA_DIR=
# Показать окно при первом логине — залогинься, потом браузер скроется. 1 = включить.
# QR_FETCH_SHOW_FIRST_LOGIN=1
# Всегда headless (невидимый). 0 = показывать окно (для отладки).
# QR_FETCH_HEADLESS=1
# Проверка сессии при неактивности (мин). При истечении — релогин. По умолчанию 10.
# QR_FETCH_SESSION_CHECK_MINUTES=10
# Держать браузер открытым между циклами. 0 = закрывать. По умолчанию 1.
# QR_FETCH_KEEP_BROWSER=1
# Пауза при пустой очереди (сек). По умолчанию 15.
# QR_FETCH_IDLE_SLEEP_SEC=15
# Минимальный возраст ЭПЛ для QR (мин). 0 = в т.ч. только что подписанные (Т1–Т4). По умолчанию 0.
# QR_FETCH_MIN_AGE_MINUTES=0
# Размер батча ЭПЛ без QR за один запрос (1–20). По умолчанию 5.
# QR_FETCH_BATCH_SIZE=5
# Задержка после загрузки страницы до первой попытки QR (мс). По умолчанию 15000 (15 сек).
# QR_FETCH_INITIAL_DELAY_MS=15000
# Ожидание статуса «QR-код получен» на странице (мс). По умолчанию 30000.
# QR_FETCH_STATUS_TIMEOUT_MS=30000
# Пауза после загрузки если статус не найден (мс). По умолчанию 10000.
# QR_FETCH_WAIT_AFTER_LOAD_MS=10000
# Мин. размер изображения QR в байтах (заглушки отсекаются). По умолчанию 2000.
# QR_FETCH_MIN_IMAGE_BYTES=2000