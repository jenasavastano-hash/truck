# ——— Наше приложение (фронт) ———
# URL, где открывается наш сайт: локально (127.0.0.1:3000) или прод (Vercel и т.п.)
E2E_BASE_URL=http://127.0.0.1:3000

# Логин/пароль для входа в наше приложение (роли: админ, водитель, менеджер)
E2E_ADMIN_USERNAME=
E2E_ADMIN_PASSWORD=
E2E_DRIVER_USERNAME=
E2E_DRIVER_PASSWORD=
E2E_MANAGER_USERNAME=
E2E_MANAGER_PASSWORD=

# ——— Такском (epl.taxcom.ru) — для проверки подписания в ЛК ———
E2E_TAKSKOM_URL=https://epl.taxcom.ru

# Такском: учётные данные по ролям (телефон/логин + пароль)
TAKSKOM_MECHANIC_PHONE=
TAKSKOM_MECHANIC_PASSWORD=
TAKSKOM_MEDIC_PHONE=
TAKSKOM_MEDIC_PASSWORD=
TAKSKOM_DISPATCHER_PHONE=
TAKSKOM_DISPATCHER_PASSWORD=
TAKSKOM_ADMIN_USERNAME=
TAKSKOM_ADMIN_PASSWORD=
