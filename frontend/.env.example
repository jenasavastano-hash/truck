# Скопируй в `.env.development` или задай в CI.
# Порт бэкенда должен совпадать с `PORT` в `backend/.env`.

VITE_API_URL=http://127.0.0.1:5000/api

# Точки входа (лендинг, /entry/login, модалка). По умолчанию в коде уже прод-URL; здесь можно переопределить.
# VITE_TAXI_LOGIN_URL=https://taxidriver.space/login
# VITE_FREIGHT_LOGIN_URL=https://truckdriver.online/login
